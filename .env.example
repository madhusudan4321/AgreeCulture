# ============================================================
#  AgreeCulture — Environment Variables (TEMPLATE)
# ============================================================
#  Copy this file to .env and fill in your keys.
#  NEVER commit .env to git — it's already in .gitignore.
# ============================================================

# ── PRIMARY AI: Google Gemini (FREE) ──────────────────────
# Get key at: https://aistudio.google.com/
# Click: Get API Key -> Create API key -> Copy
GEMINI_API_KEY=your_gemini_api_key_here

# ── SECONDARY AI: OpenRouter (FREE models available) ───────
# Get key at: https://openrouter.ai/
# Click: Sign Up (free) -> Keys -> Create Key -> Copy
# Free models used: Llama 3.1, Mistral 7B, Gemma 2
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Flask ──────────────────────────────────────────────────
FLASK_SECRET_KEY=agreeCulture_dev_secret_2024
